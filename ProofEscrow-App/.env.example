# Trustless Work API
# Get your key at https://app.trustlesswork.com
VITE_TRUSTLESS_API_KEY=

# Pinata IPFS — for evidence file uploads
# Get your JWT at https://app.pinata.cloud/keys
VITE_PINATA_JWT=

# Pusher — real-time trade notifications
# Create a free app at https://pusher.com → App Keys
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=eu
VITE_PUSHER_APP_ID=
VITE_PUSHER_SECRET=

# Your platform's Stellar address (used as releaseSigner + disputeResolver)
# Generate a testnet keypair at https://laboratory.stellar.org/#account-creator
VITE_PLATFORM_ADDRESS=
